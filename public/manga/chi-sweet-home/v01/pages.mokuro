], [893.0, 144.0], [840.0, 144.0]]], "lines": ["＞７９００８４８２"]}, {"box": [1414, 174, 1444, 495], "vertical": true, "font_size": 25, "lines_coords": [[[1416.0, 174.0], [1441.0, 174.0], [1441.0, 494.0], [1416.0, 494.0]]], "lines": ["チーズスイートホーム，こちらから"]}], "img_path": "0002.jpg"}, {"version": "0.2.4", "img_width": 1500, "img_height": 143, "blocks": [{"box": [798, 19, 1109, 133], "vertical": false, "font_size": 12, "lines_coords": [[[820.0, 25.0], [1073.0, 27.0], [1073.0, 45.0], [820.0, 44.0]], [[805.0, 44.0], [934.0, 44.0], [934.0, 58.0], [805.0, 58.0]], [[807.0, 59.0], [953.0, 59.0], [953.0, 73.0], [807.0, 73.0]], [[993.0, 60.0], [1103.0, 60.0], [1103.0, 74.0], [993.0, 74.0]], [[805.0, 73.0], [915.0, 73.0], [915.0, 88.0], [805.0, 88.0]], [[805.0, 89.0], [938.0, 89.0], [938.0, 104.0], [805.0, 104.0]], [[836.0, 105.0], [1025.0, 105.0], [1025.0, 115.0], [836.0, 115.0]]], "lines": ["私、設備される際、いたずら大好き子猫のもあああハートフルストーリー", "高野料金・新・インク・絵のお", "第一部書、オールカケージはほとんど", "学園に乗たに存在したものを含む", "青森県間、なし〈採り込んで", "保育方法「気分がブルーなとき」", "★．．．○古田家の間取り初め勝！？えかわいいし"]}, {"box": [794, 17, 1111, 134], "vertical": false, "font_size": 10, "lines_coords": [[[834.0, 17.0], [899.0, 17.0], [899.0, 27.0], [834.0, 27.0]]], "lines": ["は．．．当然似たん"]}, {"box": [1186, 94, 1279, 127], "vertical": false, "font_size": 10, "lines_coords": [[[1192.0, 92.0], [1272.0, 92.0], [1272.0, 107.0], [1192.0, 107.0]], [[1193.0, 117.0], [1227.0, 117.0], [1227.0, 127.0], [1193.0, 127.0]]], "lines": ["モーニングやＣＤメ１０を", "おまえのほうにも"]}, {"box": [361, 13, 711, 102], "vertical": false, "font_size": 21, "lines_coords": [[[361.0, 16.0], [708.0, 17.0], [708.0, 46.0], [361.0, 45.0]], [[366.0, 49.0], [708.0, 49.0], [708.0, 68.0], [366.0, 68.0]], [[435.0, 83.0], [609.0, 81.0], [609.0, 97.0], [435.0, 99.0]]], "lines": ["この子猫、拾ってください。", "モーニングで大人気の猫漫画、完全オールカラーで単行本化", "ペット禁止のマンシヨンに住む家族だった"]}, {"box": [733, 4, 761, 141], "vertical": true, "font_size": 24, "lines_coords": [[[736.0, 4.0], [760.0, 4.0], [757.0, 138.0], [733.0, 138.0]]], "lines": ["こなみがなた"]}], "im