78.0, 817.0]]], "lines": ["ぼくはもう", "生きてるのが", "いやになっちゃった。"]}, {"box": [360, 628, 440, 733], "vertical": true, "font_size": 24, "lines_coords": [[[415.0, 630.0], [440.0, 630.0], [440.0, 712.0], [415.0, 712.0]], [[389.0, 631.0], [408.0, 631.0], [408.0, 733.0], [389.0, 733.0]], [[360.0, 628.0], [387.0, 628.0], [387.0, 682.0], [360.0, 682.0]]], "lines": ["そんなに", "気を落とす", "なよ。"]}, {"box": [64, 618, 172, 772], "vertical": true, "font_size": 23, "lines_coords": [[[135.0, 619.0], [165.0, 618.0], [167.0, 691.0], [138.0, 692.0]], [[110.0, 621.0], [135.0, 621.0], [135.0, 686.0], [110.0, 686.0]], [[85.0, 622.0], [106.0, 622.0], [108.0, 724.0], [87.0, 724.0]], [[64.0, 624.0], [80.0, 624.0], [80.0, 771.0], [64.0, 771.0]]], "lines": ["運命は、", "変える", "ことだって", "てきるんだから。"]}, {"box": [672, 880, 700, 1000], "vertical": true, "font_size": 28, "lines_coords": [[[672.0, 881.0], [700.0, 881.0], [700.0, 1000.0], [672.0, 1000.0]]], "lines": ["ほんと！？"]}, {"box": [515, 870, 614, 976], "vertical": true, "font_size": 25, "lines_coords": [[[592.0, 875.0], [614.0, 875.0], [614.0, 957.0], [592.0, 957.0]], [[567.0, 875.0], [588.0, 875.0], [588.0, 976.0], [567.0, 976.0]], [[536.0, 870.0], [568.0, 870.0], [568.0, 923.0], [536.0, 923.0]], [[515.0, 874.0], [540.0, 874.0], [540.0, 956.0], [515.0, 956.0]]], "lines": ["ぼくらは", "そのために", "きた", "んだ。あ"]}, {"box": [238, 880, 282, 945], "vertical": true, "font_size": 31, "lines_coords": [[[251.0, 880.0], [282.0, 880.0], [282.0, 945.0], [251.0, 945.0]]], "lines": ["しかし"]}, {"box": [74, 877, 185, 970], "vertical": true, "font_size": 26, "lines_coords": [[[149.0, 877.0], [179.0, 877.0], [179.0, 942.0], [149.0, 942.0]], [[124.0, 877.0], [153.0, 877.0], [153.0, 943.0], [124.0, 943.0]], [[103.0, 878.0], [124.0, 878.0], [124.0, 959.0], [103.0, 959.0]], [[77.0, 878.0], [101.0, 878.0], [99.0, 970.0], [74.0, 970.0]]], "lines": ["考えて", "みると", "やっぱり", "おかしい。"]}], "img_path": "0019.jpg"}, {"version": "0.2.4", "img_width": 764, "img_height": 1200, "blocks": [{"box": [539, 124, 701, 287], "vertical": true, "font_size": 23, "lines_coords": [[[674.0, 125.0], [696.0, 125.0], [693.0, 247.0], [672.0, 247.0]], [[642.0, 124.0], [665.0, 124.0], [665.0, 287.0], [642.0, 287.0]], [[612.0, 126.0], [633.0, 126.0], [633.0, 222.0], [612.0, 222.0]], [[585.0, 124.0], [611.0, 124.0], [611.0, 186.0], [585.0, 186.0]], [[561.0, 125.0], [585.0, 125.0], [585.0, 188.0], [561.0, 188.0]], [[539.0, 125.0], [560.0, 125.0], [560.0, 193.0], [539.0, 193.0]]], "lines": ["ぼくの運命が", "変わったら、きみは", "生まれてん", "こない", "ことに", "なるぜ。"]}, {"box": [278, 126, 361, 278], "vertical": true, "font_size": 21, "lines_coords": [[[330.0, 130.0], [350.0, 130.0], [350.0, 276.0], [330.0, 276.0]], [[304.0, 127.0], [328.0, 127.0], [328.0, 269.0], [304.0, 269.0]], [[278.0, 126.0], [298.0, 126.0], [301.0, 220.0], [281.0, 220.0]]], "lines": ["心配はいらない。", "ほかでつりあい", "とるから。"]}, {"box": [90, 119, 246, 235], "vertical": true, "font_size": 21, "lines_coords": [[[215.0, 123.0], [235.0, 123.0], [235.0, 235.0], [215.0, 235.0]], [[188.0, 121.0], [208.0, 121.0], [208.0, 220.0], [188.0, 220.0]], [[165.0, 121.0], [185.0, 121.0], [185.0, 217.0], [165.0, 217.0]], [[139.0, 119.0], [164.0, 120.0], [161.0, 181.0], [137.0, 180.0]], [[112.0, 121.0], [133.0, 121.0], [133.0, 198.0], [112.0, 198.0]], [[90.0, 121.0], [111.0, 121.0], [111.0, 187.0], [90.0, 187.0]]], "lines": ["歴史の流れが", "変わっても、", "けっきょく", "ぼくは", "生まれて", "くるよ。"]}, {"box": [505, 375, 674, 505], "vertical": true, "font_size": 20, "lines_coords": [[[651.0, 375.0], [672.0, 375.0], [674.0, 460.0], [653.0, 460.0]], [[622.0, 375.0], [643.0, 375.0], [644.0, 493.0], [623.0, 493.0]], [[594.0, 376.0], [614.0, 376.0], [614.0, 486.0], [594.0, 486.0]], [[568.0, 377.0], [588.0, 377.0], [588.0, 458.0], [568.0, 458.0]], [[537.0, 375.0], [557.0, 375.0], [557.0, 476.0], [537.0, 476.0]], [[508.0, 375.0], [528.0, 375.0], [528.0, 505.0], [508.0, 505.0]]], "lines": ["たとえば、", "きみが大阪へ", "行くとする。", "いろんな", "乗りものや", "道すじがある。"]}, {"box": [481, 434, 502, 479], "vertical": true, "font_size": 21, "lines_coords": [[[481.0, 434.0], [502.0, 434.0], [502.0, 479.0], [481.0, 479.0]]], "lines": ["東京"]}, {"box": [85, 372, 280, 487], "vertical": true, "font_size": 24, "lines_coords": [[[255.0, 375.0], [280.0, 375.0], [280.0, 441.0], [255.0, 441.0]], [[229.0, 373.0], [255.0, 373.0], [255.0, 440.0], [229.0, 440.0]], [[207.0, 375.0], [227.0, 375.0], [227.0, 479.0], [207.0, 479.0]], [[176.0, 375.0], [196.0, 375.0], [196.0, 458.0], [176.0, 458.0]], [[146.0, 375.0], [166.0, 375.0], [166.0, 473.0], [146.0, 473.0]], [[108.0, 372.0], [144.0, 372.0], [144.0, 439.0], [108.0, 439.0]], [[85.0, 375.0], [106.0, 375.0], [107.0, 487.0], [86.0, 487.0]]], "lines": ["だけど、", "どれを", "えらんでも", "力角さえ", "正しければ", "大阪へ", "着けるんだ。"]}, {"box": [646, 624, 693, 783], "vertical": true, "font_size": 20, "lines_coords": [[[672.0, 624.0], [692.0, 624.0], [692.0, 782.0], [672.0, 782.0]], [[646.0, 624.0], [666.0, 624.0], [666.0, 767.0], [646.0, 767.0]]], "lines": ["このドラえもんが", "つきっきりで．．．"]}, {"box": [454, 622, 509, 731], "vertical": true, "font_size": 23, "lines_coords": [[[485.0, 623.0], [509.0, 623.0], [509.0, 707.0], [485.0, 707.0]], [[456.0, 622.0], [478.0, 622.0], [475.0, 730.0], [454.0, 730.0]]], "lines": ["めんどう", "見てやるよ"]}, {"box": [364, 625, 410, 716], "vertical": true, "font_size": 20, "lines_coords": [[[387.0, 625.0], [408.0, 625.0], [410.0, 713.0], [389.0, 713.0]], [[364.0, 626.0], [384.0, 626.0], [384.0, 716.0], [364.0, 716.0]]], "lines": ["よろしく、", "よろしく。"]}, {"box": [56, 622, 155, 716], "vertical": true, "font_size": 29, "lines_coords": [[[125.0, 623.0], [155.0, 623.0], [155.0, 669.0], [125.0, 669.0]], [[99.0, 622.0], [137.0, 622.0], [137.0, 675.0], [99.0, 675.0]], [[77.0, 623.0], [106.0, 623.0], [106.0, 696.0], [77.0, 696.0]], [[56.0, 624.0], [76.0, 624.0], [76.0, 714.0], [56.0, 714.0]]], "lines": ["わか", "って", "くれて、", "よかった。"]}, {"box": [449, 878, 584, 979], "vertical": true, "font_size": 24, "lines_coords": [[[560.0, 878.0], [584.0, 878.0], [584.0, 963.0], [560.0, 963.0]], [[534.0, 878.0],