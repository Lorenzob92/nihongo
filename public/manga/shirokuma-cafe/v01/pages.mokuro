{"version": "0.2.4", "title": "v01", "title_uuid": "2ff63786-0de5-45dd-b9ac-226de973a877", "volume": "pages", "volume_uuid": "5fb2827b-e3ea-4034-993b-2b21849896fa", "pages": [{"version": "0.2.4", "img_width": 1024, "img_height": 814, "blocks": [{"box": [54, 55, 301, 168], "vertical": false, "font_size": 14, "lines_coords": [[[113.0, 54.0], [243.0, 54.0], [243.0, 71.0], [113.0, 71.0]], [[65.0, 73.0], [292.0, 72.0], [292.0, 90.0], [65.0, 91.0]], [[62.0, 93.0], [300.0, 92.0], [300.0, 110.0], [62.0, 111.0]], [[126.0, 114.0], [242.0, 113.0], [242.0, 128.0], [126.0, 129.0]], [[57.0, 134.0], [188.0, 134.0], [188.0, 148.0], [57.0, 148.0]], [[73.0, 153.0], [211.0, 153.0], [211.0, 167.0], [73.0, 167.0]]], "lines": ["南の島とか海が大好きです。", "「年中シャツー様で・雨を見て暮らしたいです。", "メンテームはそのアだけの調査でつけてみました。", "今はまだ街から通り街の", "小さな役目に生活してます。", "地中のもころかいな気分です。"]}, {"box": [128, 424, 272, 511], "vertical": false, "font_size": 13, "lines_coords": [[[144.0, 424.0], [256.0, 424.0], [256.0, 441.0], [144.0, 441.0]], [[144.0, 448.0], [252.0, 448.0], [252.0, 462.0], [144.0, 462.0]], [[160.0, 464.0], [237.0, 464.0], [237.0, 478.0], [160.0, 478.0]], [[130.0, 480.0], [268.0, 480.0], [268.0, 494.0], [130.0, 494.0]], [[137.0, 496.0], [259.0, 496.0], [259.0, 510.0], [137.0, 510.0]]], "lines": ["ヒガァロハ", "２月１０日生まれの水瓶を。", "血液型はたぶんん", "「月日Ｎｏｗｅｓｓ」２００６年４月号にて", "「しろくまカフェ」でテビュー。"]}, {"box": [164, 658, 284, 679], "vertical": false, "font_size": 18, "lines_coords": [[[164.0, 661.0], [284.0, 658.0], [284.0, 676.0], [164.0, 679.0]]], "lines": ["月刊フラワース"]}, {"box": [109, 671, 292, 760], "vertical": false, "font_size": 14, "lines_coords": [[[131.0, 712.0], [283.0, 712.0], [283.0, 729.0], [131.0, 729.0]], [[149.0, 730.0], [252.0, 730.0], [252.0, 744.0], [149.0, 744.0]], [[114.0, 743.0], [284.0, 744.0], [284.0, 761.0], [114.0, 760.0]]], "lines": ["お客さんのリリーストレーニングで", "毎月２８日ごろ発売", "おまえが自分ではないのですが、それでも"]}, {"box": [595, 28, 783, 77], "vertical": false, "font_size": 16, "lines_coords": [[[596.0, 27.0], [781.0, 27.0], [781.0, 45.0], [596.0, 45.0]]], "lines": ["この時期は、これからもうちょっとした"]}, {"box": [865, 54, 904, 81], "vertical": false, "font_size": 29, "lines_coords": [[[865.0, 52.0], [904.0, 52.0], [904.0, 83.0], [865.0, 83.0]]], "lines": ["！"]}, {"box": [998, 240, 1011, 355], "vertical": true, "font_size": 13, "lines_coords": [[[998.0, 240.0], [1011.0, 240.0], [1011.0, 355.0], [998.0, 355.0]]], "lines": ["．．．"]}, {"box": [999, 448, 1012, 557], "vertical": true, "font_size": 13, "lines_coords": [[[999.0, 448.0], [1012.0, 448.0], [1012.0, 557.0], [999.0, 557.0]]], "lines": ["ヒガ、アロハ"]}, {"box": [556, 749, 830, 780], "vertical": false, "font_size": 21, "lines_coords": [[[570.0, 753.0], [685.0, 753.0], [685.0, 774.0], [570.0, 774.0]]], "lines": ["．．．"]}], "img_path": "0001.jpg"}, {"version": "0.2.4", "img_width": 687, "img_height": 1024, "blocks": [{"box": [372, 39, 467, 54], "vertical": false, "font_size": 13, "lines_coords": [[[372.0, 39.0], [467.0, 41.0], [467.0, 54.0], [372.0, 52.0]]], "lines": ["ここ、ミルトの「ん」"]}], "img_path": "0002.jpg"}, {"version": "0.2.4", "img_width": 681, "img_height": 1024, "blocks": [{"box": [337, 72, 487, 95], "vertical": false, "font_size": 18, "lines_coords": [[[340.0, 73.0], [483.0, 76.0], [483.0, 94.0], [340.0, 91.0]]], "lines": ["いらっしゃいませ"]}, {"box": [68, 667, 238, 734], "vertical": false, "font_size": 65, "lines_coords": [[[69.0, 667.0], [238.0, 669.0], [237.0, 734.0], [68.0, 732.0]]], "lines": ["フリーＡＲＬＥＮＥＮＯＫ"]}, {"box": [79, 862, 220, 899], "vertical": false, "font_size": 18, "lines_coords": [[[102.0, 862.0], [185.0, 862.0], [185.0, 879.0], [102.0, 879.0]], [[81.0, 878.0], [218.0, 881.0], [218.0, 899.0], [81.0, 896.0]]], "lines": ["ＯＲＦＡＭＩＣ", "「ＦｏｏｂＳ、ＰＲＩＭＫＳ"]}], "img_path": "0003.jpg"}, {"version": "0.2.4", "img_width": 690, "img_height": 1024, "blocks": [{"box": [74, 129, 260, 143], "vertical": false, "font_size": 14, "lines_coords": [[[74.0, 129.0], [260.0, 129.0], [260.0, 143.0], [74.0, 143.0]]], "lines": ["しろくまカフェへようこそ"]}, {"box": [81, 150, 204, 219], "vertical": false, "font_size": 19.0, "lines_coords": [[[82.0, 150.0], [200.0, 150.0], [200.0, 170.0], [82.0, 170.0]], [[81.0, 175.0], [204.0, 175.0], [204.0, 195.0], [81.0, 195.0]], [[84.0, 194.0], [127.0, 200.0], [124.0, 219.0], [81.0, 213.0]], [[119.0, 198.0], [175.0, 198.0], [175.0, 215.0], [119.0, 215.0]]], "lines": ["登場編．．．．．．！！", "フィッシング編．．．！！", "スノーボ", "一ボード編"]}, {"box": [278, 97, 404, 111], "vertical": false, "font_size": 14, "lines_coords": [[[278.0, 97.0], [404.0, 97.0], [404.0, 111.0], [278.0, 111.0]]], "lines": ["１０日ＮＵＪメニュ"]}, {"box": [57, 192, 155, 430], "vertical": true, "font_size": 42.666666666666664, "lines_coords": [[[119.0, 213.0], [136.0, 213.0], [136.0, 380.0], [119.0, 380.0]], [[106.0, 217.0], [126.0, 217.0], [126.0, 391.0], [106.0, 391.0]], [[57.0, 195.0], [148.0, 192.0], [155.0, 427.0], [64.0, 430.0]]], "lines": ["媚フ諌イたさ数", "見エ目バ葉屋車編", "スノーポーお花見箱パワエフェ朝の日融通アルバイト落ち場たされパン屋さんも自動車教習は即走輪．．．お正月難アルハイド"]}, {"box": [117, 239, 202, 337], "vertical": false, "font_size": 38.333333333333336, "lines_coords": [[[133.0, 242.0], [171.0, 239.0], [172.0, 254.0], [134.0, 257.0]], [[117.0, 251.0], [198.0, 247.0], [202.0, 333.0], [121.0, 337.0]], [[142.0, 292.0], [152.0, 282.0], [162.0, 292.0], [152.0, 302.0]]], "lines": ["福岡市のフェア編", "アフェブは、日曜日のバイトが来た者が若干していた", "．．．"]}, {"box": [135, 318, 162, 346], "vertical": false, "font_size": 16.0, "lines_coords": [[[138.0, 318.0], [146.0, 318.0], [146.0, 332.0], [138.0, 332.0]], [[135.0, 328.0], [162.0, 328.0], [162.0, 346.0], [135.0, 346.0]]], "lines": ["さ", "ん編"]}, {"box": [85, 417, 235, 430], "vertical": false, "font_size": 13, "lines_coords": [[[85.0, 417.0], [235.0, 417.0], [235.0, 430.0], [85.0, 430.0]]], "lines": ["アルバイト編２．．．"]}, {"box": [82, 431, 306, 483], "vertical": false, "font_size": 21.0, "lines_coords": [[[84.0, 431.0], [135.0, 433.0], [134.0, 454.0], [83.0, 452.0]], [[82.0, 462.0], [306.0, 462.0], [306.0, 483.0], [82.0, 483.0]]], "lines": ["動物園編", "ドンダくんの遠足、高温泉ツフー．．．？」"]}, {"box": [292, 154, 308, 453], "vertical": true, "font_size": 14, "lines_coords": [[[294.0, 154.0], [308.0, 154.0], [306.0, 453.0], [292.0, 453.0]]], "lines": ["５９は１７１２月２９４１５４９３５３９７"]}, {"box": [318, 122, 598, 488], "vertical": false, "font_size": 28, "lines_coords": [[[355.0, 122.0], [530.0, 120.0], [530.0, 145.0], [355.0, 147.0]], [[368.0, 150.0], [500.0, 148.0], [500.0, 169.0], [368.0, 171.0]], [[516.0, 155.0], [592.0, 155.0], [592.0, 173.0], [516.0, 173.0]], [[367.0, 171.0], [591.0, 172.0], [591.0, 194.0], [367.0, 193.0]], [[369.0, 192.0], [408.0, 192.0], [408.0, 214.0], [369.0, 214.0]], [[367.0, 213.0], [424.0, 213.0], [424.0, 235.0], [367.0, 235.0]], [[429.0, 218.0], [592.0, 218.0], [592.0, 236.0], [429.0, 236.0]], [[366.0, 234.0], [595.0, 234.0], [595.0, 265.0], [366.0, 265.0]], [[368.0, 251.0], [443.0, 259.0], [441.0, 284.0], [366.0, 276.0]], [[369.0, 276.0], [485.0, 276.0], [485.0, 301.0], [369.0, 301.0]], [[501.0, 279.0], [592.0, 279.0], [592.0, 304.0], [501.0, 304.0]], [[356.0, 307.0], [590.0, 306.0], [590.0, 328.0], [356.0, 329.0]], [[354.0, 331.0], [594.0, 330.0], [594.0, 354.0], [354.0, 355.0]], [[318.0, 366.0], [461.0, 280.0], [519.0, 379.0], [376.0, 466.0]], [[402.0, 376.0], [469.0, 372.0], [470.0, 394.0], [403.0, 398.0]], [[404.0, 390.0], [486.0, 390.0], [486.0, 419.0], [404.0, 419.0]], [[407.0, 409.0], [473.0, 409.0], [473.0, 431.0], [407.0, 431.0]], [[561.0, 369.0], [581.0, 369.0], [579.0, 481.0], [559.0, 481.0]], [[369.0, 428.0], [470.0, 428.0], [470.0, 446.0], [369.0, 446.0]], [[368.0, 443.0], [424.0, 443.0], [424.0, 464.0], [368.0, 464.0]], [[371.0, 464.0], [436.0, 464.0], [436.0, 478.0], [371.0, 478.0]]], "lines": ["シロクマくんと仲間たち", "バンダくん編．．．", "．．．", "クリズリーさん編．．．", "家出編", "永田編家出編２", "うっ．．．", "家庭教えて．．．", "ペンキンこれが冬眠編．．．ということ", "冬眠場．．．", "．．．", "シロクマくんの布団バーベキューヨールに", "シログマスタイルは、シロウマくんの休日１２ヶ月〜〜〜っ！！", "．．．", "くまレシピ０くましシビ２くまルシピタ", "くまレシピ２くまルシビ＠．．．くましシビ４．．", "まレンピョ・まレシピ４・キーンヒョン", "１９００年１０月", "しっくまレンとはいしろくましシビら・雑干でス", "しっくまし巻末ふろくあとがま．．．", "あとかき．．．"]}, {"box": [70, 643, 93, 732], "vertical": true, "font_size": 21, "lines_coords": [[[70.0, 643.0], [91.0, 643.0], [93.0, 717.0], [72.0, 717.0]]], "lines": ["オイシ"]}, {"box": [385, 535, 466, 552], "vertical": false, "font_size": 17, "lines_coords": [[[385.0, 535.0], [466.0, 535.0], [466.0, 552.0], [385.0, 552.0]]], "lines": ["パンダくん"]}, {"box": [378, 546, 550, 605], "vertical": false, "font_size": 17, "lines_coords": [[[386.0, 567.0], [540.0, 567.0], [540.0, 584.0], [386.0, 584.0]], [[388.0, 588.0], [536.0, 588.0], [536.0, 605.0], [388.0, 605.0]]], "lines": ["「しろくまカフエ♪の常連と", "ちょっと面倒くさがり屋。"]}, {"box": [468, 900, 553, 914], "vertical": false, "font_size": 15, "lines_coords": [[[468.0, 900.0], [553.0, 900.0], [553.0, 914.0], [468.0, 914.0]]], "lines": ["フェンさん"]}, {"box": [464, 931, 633, 968], "vertical": false, "font_size": 15, "lines_coords": [[[466.0, 932.0], [619.0, 931.0], [619.0, 948.0], [466.0, 949.0]], [[464.0, 954.0], [633.0, 954.0], [633.0, 968.0], [464.0, 968.0]]], "lines": ["じろくまカフェの常連客", "世話焼きでちょっとせっかち。"]}], "img_path": "0004.jpg"}, {"version": "0.2.4", "img_width": 690, "img_height": 1024, "blocks": [{"box": [351, 80, 452, 99], "vertical": false, "font_size": 17, "lines_coords": [[[351.0, 80.0], [452.0, 82.0], [452.0, 99.0], [351.0, 97.0]]], "lines": ["シロクマくん"]}, {"box": [378, 111, 556, 151], "vertical": false, "font_size": 17, "lines_coords": [[[379.0, 111.0], [554.0, 112.0], [554.0, 129.0], [379.0, 128.0]], [[383.0, 133.0], [528.0, 133.0], [528.0, 150.0], [383.0, 150.0]]], "lines": ["「しろくまカフェのマスター。", "マイペースでしつかり者。"]}, {"box": [464, 310, 611, 385], "vertical": false, "font_size": 17, "lines_coords": [[[475.0, 313.0], [598.0, 313.0], [598.0, 330.0], [475.0, 330.0]], [[469.0, 343.0], [586.0, 343.0], [586.0, 363.0], [469.0, 363.0]], [[470.0, 367.0], [601.0, 367.0], [601.0, 380.0], [470.0, 380.0]]], "lines": ["グリズリーさん", "シロクマくんの友人、", "とってもワイルトなだ"]}, {"box": [468, 664, 499, 740], "vertical": true, "font_size": 29, "lines_coords": [[[468.0, 665.0], [497.0, 664.0], [499.0, 739.0], [470.0, 740.0]]], "lines": ["ロクサ"]}, {"box": 