], [233.0, 179.0], [233.0, 223.0], [215.0, 223.0]], [[184.0, 148.0], [213.0, 144.0], [225.0, 237.0], [196.0, 241.0]]], "lines": ["紫氏", "Ｍ稿ぶ７７"]}, {"box": [308, 250, 399, 317], "vertical": false, "font_size": 67, "lines_coords": [[[308.0, 250.0], [399.0, 250.0], [399.0, 317.0], [308.0, 317.0]]], "lines": ["気分は吉田松陰．．．"]}, {"box": [292, 340, 371, 360], "vertical": false, "font_size": 18, "lines_coords": [[[292.0, 340.0], [371.0, 342.0], [371.0, 360.0], [292.0, 358.0]]], "lines": ["ちがうやろ"]}, {"box": [315, 420, 373, 438], "vertical": false, "font_size": 18, "lines_coords": [[[315.0, 420.0], [373.0, 420.0], [373.0, 438.0], [315.0, 438.0]]], "lines": ["行ってた"]}, {"box": [269, 376, 356, 422], "vertical": false, "font_size": 20.5, "lines_coords": [[[269.0, 380.0], [343.0, 376.0], [344.0, 397.0], [270.0, 401.0]], [[278.0, 402.0], [354.0, 396.0], [356.0, 416.0], [280.0, 422.0]]], "lines": ["前はすぐ", "散歩とか"]}, {"box": [64, 302, 167, 358], "vertical": false, "font_size": 17, "lines_coords": [[[67.0, 319.0], [165.0, 319.0], [165.0, 336.0], [67.0, 336.0]], [[69.0, 340.0], [156.0, 340.0], [156.0, 357.0], [69.0, 357.0]]], "lines": ["ハロンダを頼みで", "作るんでかー"]}, {"box": [92, 386, 223, 424], "vertical": false, "font_size": 14, "lines_coords": [[[95.0, 389.0], [202.0, 389.0], [202.0, 403.0], [95.0, 403.0]], [[95.0, 409.0], [219.0, 409.0], [219.0, 423.0], [95.0, 423.0]]], "lines": ["はじめはビンと", "こなかったですか"]}, {"box": [523, 447, 666, 969], "vertical": false, "font_size": 27, "lines_coords": [[[583.0, 477.0], [620.0, 477.0], [620.0, 501.0], [583.0, 501.0]], [[558.0, 476.0], [582.0, 476.0], [582.0, 509.0], [558.0, 509.0]], [[539.0, 482.0], [557.0, 482.0], [557.0, 509.0], [539.0, 509.0]], [[538.0, 505.0], [644.0, 509.0], [643.0, 538.0], [537.0, 534.0]], [[543.0, 533.0], [643.0, 533.0], [643.0, 554.0], [543.0, 554.0]], [[556.0, 555.0], [643.0, 555.0], [643.0, 584.0], [556.0, 584.0]], [[545.0, 554.0], [561.0, 554.0], [561.0, 577.0], [545.0, 577.0]], [[537.0, 564.0], [652.0, 564.0], [652.0, 607.0], [537.0, 607.0]], [[545.0, 594.0], [560.0, 594.0], [560.0, 623.0], [545.0, 623.0]], [[557.0, 601.0], [633.0, 604.0], [632.0, 625.0], [556.0, 622.0]], [[545.0, 632.0], [639.0, 632.0], [639.0, 650.0], [545.0, 650.0]], [[542.0, 654.0], [645.0, 654.0], [645.0, 675.0], [542.0, 675.0]], [[541.0, 673.0], [627.0, 675.0], [627.0, 696.0], [541.0, 694.0]], [[543.0, 697.0], [650.0, 699.0], [650.0, 716.0], [543.0, 714.0]], [[541.0, 717.0], [612.0, 719.0], [612.0, 737.0], [541.0, 735.0]], [[541.0, 740.0], [659.0, 740.0], [659.0, 760.0], [541.0, 760.0]], [[542.0, 770.0], [646.0, 774.0], [645.0, 798.0], [541.0, 794.0]], [[541.0, 792.0], [645.0, 795.0], [644.0, 819.0], [540.0, 816.0]], [[539.0, 824.0], [653.0, 827.0], [653.0, 847.0], [539.0, 844.0]], [[533.0, 847.0], [645.0, 850.0], [645.0, 871.0], [533.0, 868.0]], [[523.0, 862.0], [666.0, 862.0], [666.0, 942.0], [523.0, 942.0]]], "lines": ["まず", "ババ", "や", "お手伝いくだ", "さった大下先生", "阪デザイナー", "大", "大阪デザイナー専門学校マンガ", "いいです", "「科のみんな", "いつも万カ主して", "くれろ海月ちゃん", "ｎｏｇｌｏちゃん", "みーさん．．．ふねさん", "ｋ－ｃｏ．さん", "前の職場のみな", "お世話になって", "いる編集の方や", "そして本を読んで", "くださったみなさま", "本当に幸当にやおりがとう！！"]}, {"box": [253, 691, 374, 741], "vertical": false, "font_size": 30, "lines_coords": [[[253.0, 691.0], [374.0, 691.0], [374.0, 722.0], [253.0, 722.0]], [[254.0, 713.0], [357.0, 713.0], [357.0, 741.0], [254.0, 741.0]]], "lines": ["寒風吹きすさぶ", "河原で最影会"]}, {"box": [115, 702, 196, 720], "vertical": false, "font_size": 18, "lines_coords": [[[115.0, 702.0], [195.0, 702.0], [195.0, 720.0], [115.0, 720.0]]], "lines": ["カワイイネ！"]}, {"box": [71, 743, 160, 760], "vertical": false, "font_size": 14, "lines_coords": [[[72.0, 745.0], [156.0, 743.0], [156.0, 757.0], [72.0, 759.0]]], "lines": ["いいカンジ"]}, {"box": [285, 804, 386, 865], "vertical": false, "font_size": 19, "lines_coords": [[[288.0, 805.0], [358.0, 805.0], [358.0, 822.0], [288.0, 822.0]], [[289.0, 824.0], [378.0, 820.0], [379.0, 841.0], [290.0, 845.0]], [[285.0, 845.0], [385.0, 847.0], [385.0, 865.0], [285.0, 863.0]]], "lines": ["あたたかく", "見守りっっ", "通りすぎる人たち"]}, {"box": [310, 890, 486, 938], "vertical": false, "font_size": 18, "lines_coords": [[[313.0, 894.0], [438.0, 894.0], [438.0, 914.0], [313.0, 914.0]], [[312.0, 918.0], [486.0, 921.0], [486.0, 938.0], [312.0, 935.0]]], "lines": ["楽しいと思うので、", "ぜひ作ってみてください"]}, {"box": [111, 886, 237, 924], "vertical": false, "font_size": 18, "lines_coords": [[[112.0, 886.0], [209.0, 886.0], [209.0, 903.0], [112.0, 903.0]], [[119.0, 904.0], [234.0, 902.0], [234.0, 922.0], [119.0, 924.0]]], "lines": ["リエさみとのり", "あればできます"]}], "img_path": "0167.jpg"}, {"version": "0.2.4", "img_width": 683, "img_height": 1024, "blocks": [{"box": [369, 409, 558, 419], "vertical": false, "font_size": 10, "lines_coords": [[[369.0, 409.0], [558.0, 409.0], [558.0, 419.0], [369.0, 419.0]]], "lines": ["ＦＬＯＷＥＲＣＤＭＣＳＳＰＥＯＡＬ"]}, {"box": [361, 474, 561, 499], "vertical": false, "font_size": 11.5, "lines_coords": [[[361.0, 474.0], [561.0, 474.0], [561.0, 487.0], [361.0, 487.0]], [[364.0, 489.0], [437.0, 489.0], [437.0, 499.0], [364.0, 499.0]]], "lines": ["２００８年３月３１日初版第１副発行（検印廃止）", "２０１２年４月２１日"]}, {"box": [450, 441, 559, 457], "vertical": false, "font_size": 15, "lines_coords": [[[450.0, 441.0], [559.0, 442.0], [559.0, 457.0], [450.0, 456.0]]], "lines": ["しろくまカフェ"]}, {"box": [454, 489, 509, 499], "vertical": false, "font_size": 10, "lines_coords": [[[454.0, 489.0], [509.0, 489.0], [509.0, 499.0], [454.0, 499.0]]], "lines": ["第１７回発行"]}, {"box": [292, 587, 562, 602], "vertical": false, "font_size": 14, "lines_coords": [[[292.0, 588.0], [562.0, 587.0], [562.0, 601.0], [292.0, 602.0]]], "lines": ["「月刊ｆｏｖｅｒｓ」２００６年４、５、１０、１１月号、２００７年１〜３、"]}, {"box": [441, 521, 562, 561], "vertical": false, "font_size": 14.0, "lines_coords": [[[441.0, 523.0], [559.0, 521.0], [559.0, 535.0], [441.0, 537.0]], [[449.0, 547.0], [562.0, 547.0], [562.0, 561.0], [449.0, 561.0]]], "lines": ["著者・ヒガアロハ", "発行者「丸澤」滋"]}, {"box": [400, 602, 563, 615], "vertical": false, "font_size": 13, "lines_coords": [[[400.0, 602.0], [563.0, 602.0], [563.0, 615.0], [400.0, 615.0]]], "lines": ["５〜１２月号、２００８年し、２月時期"]}, {"box": [377, 638, 564, 653], "vertical": false, "font_size": 14, "lines_coords": [[[377.0, 639.0], [564.0, 638.0], [564.0, 652.0], [377.0, 653.0]]], "lines": ["単行本編集者武者正昭、Ｒ［アール］"]}, {"box": [451, 623, 563, 636], "vertical": false, "font_size": 13, "lines_coords": [[[451.0, 623.0], [563.0, 623.0], [563.0, 636.0], [451.0, 636.0]]], "lines": ["連載担当Ｒ［アール］"]}, {"box": [542, 574, 563, 586], "vertical": false, "font_size": 12, "lines_coords": [[[542.0, 574.0], [563.0, 574.0], [563.0, 586.0], [542.0, 586.0]]], "lines": ["初出"]}, {"box": [367, 654, 563, 722], "vertical": false, "font_size": 13.0, "lines_coords": [[[414.0, 655.0], [563.0, 654.0], [563.0, 668.0], [414.0, 669.0]], [[412.0, 678.0], [563.0, 678.0], [563.0, 692.0], [412.0, 692.0]], [[387.0, 694.0], [563.0, 694.0], [563.0, 707.0], [387.0, 707.0]], [[367.0, 711.0], [563.0, 710.0], [563.0, 721.0], [367.0, 722.0]]], "lines": ["単行本編集資任者・武者正昭", "発行所－株式会社小学館", "〒１０１－２００１東京都千代田区一ツ橋？よー", "ＴＥＬ・販売・０３－５２０１こちらもブロ集まりにより、最近は"]}, {"box": [393, 741, 563, 756], "vertical": false, "font_size": 14, "lines_coords": [[[393.0, 742.0], [563.0, 741.0], [563.0, 755.0], [393.0, 756.0]]], "lines": ["印刷所＿凸版印刷株式会社"]}, {"box": [219, 799, 576, 922], "vertical": false, "font_size": 13, "lines_coords": [[[220.0, 800.0], [563.0, 798.0], [563.0, 813.0], [220.0, 815.0]], [[220.0, 812.0], [563.0, 810.0], [563.0, 825.0], [220.0, 827.0]], [[222.0, 825.0], [460.0, 825.0], [460.0, 839.0], [222.0, 839.0]], [[220.0, 836.0], [564.0, 835.0], [564.0, 850.0], [220.0, 851.0]], [[221.0, 848.0], [558.0, 847.0], [558.0, 862.0], [221.0, 863.0]], [[220.0, 860.0], [563.0, 859.0], [563.0, 874.0], [220.0, 875.0]], [[220.0, 872.0], [562.0, 871.0], [562.0, 886.0], [220.0, 887.0]], [[220.0, 885.0], [378.0, 883.0], [378.0, 898.0], [220.0, 900.0]], [[221.0, 896.0], [563.0, 895.0], [563.0, 910.0], [221.0, 911.0]], [[222.0, 909.0], [417.0, 909.0], [417.0, 923.0], [222.0, 923.0]]], "lines": ["●設定により対応しておりますが、あとではありません。ありがとうございます。「体のページの状況はほうが明日の間違いでしょうか」というのは、この間にもちょっとしていました。", "それにしても、どうしようとしていたのかわかりますからこそ、考えられているのではないでしょうか。そ、そうなんだから、その時間帯にあてはお送りください。", "最初は、まるでしょう。社会的にで、お取り替えていたします。第１９回目に「自己ＬＩＮＥＴＥＲＩＴＥＮ」では", "１０月に、「２０１７年３月２３日土．．．●お休みのお客さまには「お客様」ということではないのですが、昨日のお客さんは、お客様のおすすることは、法律で認められた場合、セットカードをございました。", "それじゃあ、ここまで言っているのですが、それで一緒に、そういうこともありませんです。あらかじゃなくても、ちょっともありがとうございますのでお話をおかげください。ここで", "それは、これからの取り付け料理店舗でクープが開催されたこのようなものはありませんでしたが、実際には「ロビーすることは、教師だけではない」と思います。", "世界中では、カップランスタイルを初めて、楽しくなっています。今度などにそれであれば、このようなことですが、それらの場合は、事前に「不思議なスターク」（火）の", "それでも、楽しんですね。中国には、３０１３年１０月１３日には１０日（日）です。ファンタルファイルの", "これからのＷｉｎｄｏｗｓのアプリケーションの基本的なデータを作成していますので、でも例外で作る際にくれています。債務整体の", "第三者による本書の電それはまあいいけど．．．これから一生的処理も認められておりません。"]}, {"box": [289, 936, 488, 953], "vertical": false, "font_size": 15, "lines_coords": [[[289.0, 936.0], [484.0, 936.0], [484.0, 953.0], [289.0, 953.0]]], "lines": ["ＩＳＳＮ９７８－４－４９－１６７０３Ｃ４"]}, {"box": [472, 765, 563, 788], "vertical": false, "font_size": 11.5, "lines_coords": [[[472.0, 765.0], [563.0, 765.0], [563.0, 778.0], [472.0, 778.0]], [[488.0, 778.0], [563.0, 778.0], [563.0, 788.0], [488.0, 788.0]]], "lines": ["Ｃ）ＡｌｏｎｅＷｉｎｇｏｒ２００８．０．６．１．１６．", "ＰｒｉｎｔｅｄｉｎＪｏｐｓの"]}], "img_path": "0168.jpg"}, {"version": "0.2.4", "img_width": 681, "img_height": 1024, "blocks": [{"box": [119, 190, 448, 209], "vertical": false, "font_size": 17, "lines_coords": [[[119.0, 190.0], [448.0, 192.0], [448.0, 209.0], [119.0, 207.0]]], "lines": ["公式ＨＰ－ｈｔｔｐ：／／ｆｉｃｙｅｒｓ：ｓｈｏｇａｋｕｋｅｎ．ｃｏ．ｊｐ"]}, {"box": [82, 229, 492, 247], "vertical": false, "font_size": 17, "lines_coords": [[[82.0, 229.0], [492.0, 230.0], [492.0, 247.0], [82.0, 246.0]]], "lines": ["渡辺多恵子／田村由美赤石路代～西『側子〈波津彬子"]}, {"box": [446, 84, 615, 118], "vertical": false, "font_size": 32, "lines_coords": [[[446.0, 86.0], [615.0, 84.0], [615.0, 116.0], [446.0, 118.0]]], "lines": ["毎月２８日："]}, {"box": [80, 265, 468, 283], "vertical": false, "font_size": 16, "lines_coords": [[[80.0, 265.0], [468.0, 267.0], [468.0, 283.0], [80.0, 281.0]]], "lines": ["萩尾望鄱ノ吉田秋生さいとうちほ。やまざき貴子"]}, {"box": [80, 300, 452, 323], "vertical": false, "font_size": 20, "lines_coords": [[[80.0, 300.0], [452.0, 303.0], [452.0, 323.0], [80.0, 320.0]]], "lines": ["吉村明美／岩本ナオノ江平洋日／小玉ユキ／ほか"]}, {"box": [336, 362, 618, 389], "vertical": false, "font_size": 27, "lines_coords": [[[336.0, 362.0], [618.0, 362.0], [618.0, 389.0], [336.0, 389.0]]], "lines": ["☆読むアニマル、セラピー☆"]}, {"box": [359, 392, 618, 453], "vertical": false, "font_size": 56, "lines_coords": [[[360.0, 392.0], [618.0, 397.0], [617.0, 453.0], [359.0, 448.0]]], "lines": ["ろくまカフェ"]}, {"box": [412, 457, 609, 499], "vertical": false, "font_size": 42, "lines_coords": [[[412.0, 457.0], [609.0, 457.0], [609.0, 499.0], [412.0, 499.0]]], "lines": ["９ヒガァロハ"]}, {"box": [131, 587, 257, 643], "vertical": false, "font_size": 23, "lines_coords": [[[133.0, 587.0], [243.0, 591.0], [242.0, 616.0], [132.0, 612.0]], [[134.0, 619.0], [253.0, 621.0], [253.0, 641.0], [134.0, 639.0]]], "lines": ["ボクが活躍", "しているよ"]}, {"box": [311, 849, 530, 904], "vertical": false, "font_size": 21, "lines_coords": [[[317.0, 851.0], [467.0, 851.0], [467.0, 872.0], [317.0, 872.0]], [[316.0, 878.0], [524.0, 880.0], [524.0, 901.0], [316.0, 899.0]]], "lines": ["ボクはだいたい", "ゴロゴロしているよ」"]}, {"box": [533, 957, 616, 971], "vertical": false, "font_size": 14, "lines_coords": [[[533.0, 957.0], [616.0, 957.0], [616.0, 971.0], [533.0, 971.0]]], "lines": ["発行イ小学館"]}], "img_path": "0169.jpg"}, {"version": "0.2.4", "img_width": 681, "img_height": 1024, "blocks": [], "img_path": "0170.jpg"}, {"version": "0.2.4", "img_width": 1024, "img_height": 857, "blocks": [{"box": [42, 89, 178, 109], "vertical": false, "font_size": 16, "lines_coords": [[[46.0, 90.0], [176.0, 92.0], [176.0, 110.0], [46.0, 108.0]]], "lines": ["９了８４．０８ｍｍｉｎｉｔｈは１９７６７０３０４"]}, {"box": [40, 179, 179, 198], "vertical": false, "font_size": 12, "lines_coords": [[[49.0, 183.0], [174.0, 183.0], [174.0, 197.0], [49.0, 197.0]]], "lines": ["１９２９９７９００６４８８"]}, {"box": [217, 77, 294, 94], "vertical": false, "font_size": 13, "lines_coords": [[[221.0, 79.0], [290.0, 79.0], [290.0, 94.0], [221.0, 94.0]]], "lines": ["Ｃ９９７９＼６４８Ｅ"]}, {"box": [218, 44, 363, 60], "vertical": false, "font_size": 15, "lines_coords": [[[220.0, 44.0], [361.0, 44.0], [361.0, 61.0], [220.0, 61.0]]], "lines": ["１５５００７．４－０９－１６７Ｃ３０－４"]}, {"box": [221, 138, 381, 152], "vertical": false, "font_size": 14, "lines_coords": [[[221.0, 138.0], [381.0, 138.0], [381.0, 152.0], [221.0, 152.0]]], "lines": ["定価：本本６４８円十税"]}, {"box": [219, 167, 374, 181], "vertical": false, "font_size": 14, "lines_coords": [[[219.0, 167.0], [374.0, 167.0], [374.0, 181.0], [219.0, 181.0]]], "lines": ["雑誌４５６３０－３０．・小学館"]}, {"box": [177, 363, 423, 541], "vertical": false, "font_size": 11, "lines_coords": [[[243.0, 366.0], [362.0, 366.0], [362.0, 376.0], [243.0, 376.0]], [[212.0, 387.0], [384.0, 387.0], [384.0, 397.0], [212.0, 397.0]], [[225.0, 406.0], [375.0, 406.0], [375.0, 419.0], [225.0, 419.0]], [[236.0, 449.0], [367.0, 449.0], [367.0, 459.0], [236.0, 459.0]], [[177.0, 426.0], [419.0, 426.0], [419.0, 439.0], [177.0, 439.0]], [[213.0, 469.0], [387.0, 469.0], [387.0, 479.0], [213.0, 479.0]], [[195.0, 488.0], [405.0, 489.0], [405.0, 500.0], [195.0, 499.0]], [[242.0, 509.0], [362.0, 509.0], [362.0, 519.0], [242.0, 519.0]], [[218.0, 530.0], [380.0, 530.0], [380.0, 540.0], [218.0, 540.0]]], "lines": ["シロウマくんが経営する", "オシャレなかフェはいつも大繁盛", "そんな彼のひそかな楽しみは、", "そんなまったりした日々を", "常連客のパンダくくんとダジャーレ選手をすること。", "普段しているシロクマくんですが、", "それなりにいろんなこともあるようで．．．。", "トボけた味わいが魅力の", "動物源スロ――＆ギャグ・・ライフ。"]}, {"box": [647, 111, 808, 219], "vertical": false, "font_size": 14, "lines_coords": [[[658.0, 109.0], [704.0, 109.0], [704.0, 120.0], [658.0, 120.0]], [[652.0, 130.0], [798.0, 130.0], [798.0, 144.0], [652.0, 144.0]], [[651.0, 147.0], [740.0, 147.0], [740.0, 164.0], [651.0, 164.0]], [[649.0, 162.0], [796.0, 165.0], [796.0, 186.0], [649.0, 183.0]], [[651.0, 184.0], [806.0, 184.0], [806.0, 201.0], [651.0, 201.0]], [[650.0, 201.0], [796.0, 202.0], [796.0, 220.0], [650.0, 219.0]]], "lines": ["それでも", "キフラワーコミックススペシャル", "しろくまカフェ", "しろくまカフェ。いちごね", "しろくまカフェマソコーや", "しろくまカフェ・メロン明"]}, {"box": [877, 371, 971, 423], "vertical": false, "font_size": 10, "lines_coords": [[[886.0, 372.0], [948.0, 372.0], [948.0, 383.0], [886.0, 383.0]], [[911.0, 380.0], [962.0, 379.0], [962.0, 393.0], [911.0, 394.0]], [[900.0, 392.0], [957.0, 392.0], [957.0, 403.0], [900.0, 403.0]], [[920.0, 401.0], [952.0, 401.0], [952.0, 415.0], [920.0, 415.0]]], "lines": ["１１月１４日ストー", "．．．", "．．．", "黒木さん"]}], "img_path": "0171.jpg"}]}