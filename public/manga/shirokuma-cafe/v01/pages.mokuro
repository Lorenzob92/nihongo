ont_size": 20, "lines_coords": [[[447.0, 102.0], [511.0, 100.0], [511.0, 114.0], [447.0, 116.0]], [[456.0, 120.0], [571.0, 106.0], [574.0, 127.0], [459.0, 141.0]], [[449.0, 139.0], [595.0, 124.0], [598.0, 148.0], [452.0, 163.0]]], "lines": ["コピーして", "作るといいです", "自需コピーでＯＫな"]}, {"box": [293, 91, 370, 125], "vertical": false, "font_size": 34, "lines_coords": [[[293.0, 91.0], [370.0, 91.0], [370.0, 125.0], [293.0, 125.0]]], "lines": ["作り方"]}, {"box": [97, 176, 344, 327], "vertical": false, "font_size": 21, "lines_coords": [[[98.0, 180.0], [300.0, 180.0], [300.0, 200.0], [98.0, 200.0]], [[97.0, 211.0], [342.0, 211.0], [342.0, 232.0], [97.0, 232.0]], [[113.0, 241.0], [201.0, 245.0], [200.0, 266.0], [112.0, 262.0]], [[101.0, 274.0], [286.0, 274.0], [286.0, 295.0], [101.0, 295.0]], [[114.0, 304.0], [230.0, 307.0], [230.0, 327.0], [114.0, 324.0]]], "lines": ["０線に沿ってバーツを切り抜く", "＠頭は鼻下ののりしろをのり付けして", "円錐形にする", "３胴を円筒形にのり付けして", "頭を貼り合わせる"]}, {"box": [400, 318, 590, 349], "vertical": false, "font_size": 25, "lines_coords": [[[400.0, 324.0], [589.0, 318.0], [590.0, 343.0], [401.0, 349.0]]], "lines": ["顔が止体的になります。"]}, {"box": [479, 442, 570, 456], "vertical": false, "font_size": 14, "lines_coords": [[[479.0, 442.0], [570.0, 442.0], [570.0, 456.0], [479.0, 456.0]]], "lines": ["男占り合わせて"]}, {"box": [335, 369, 534, 421], "vertical": false, "font_size": 20.5, "lines_coords": [[[335.0, 369.0], [534.0, 369.0], [534.0, 390.0], [335.0, 390.0]], [[347.0, 401.0], [461.0, 401.0], [461.0, 421.0], [347.0, 421.0]]], "lines": ["＠手は中央の線で二つ折りして", "裏を貼り合わせる"]}, {"box": [323, 443, 403, 460], "vertical": false, "font_size": 17, "lines_coords": [[[323.0, 443.0], [403.0, 443.0], [403.0, 460.0], [323.0, 460.0]]], "lines": ["折り曲げて"]}, {"box": [228, 411, 286, 436], "vertical": false, "font_size": 23, "lines_coords": [[[228.0, 413.0], [283.0, 411.0], [284.0, 434.0], [229.0, 436.0]]], "lines": ["合体！"]}, {"box": [333, 609, 525, 631], "vertical": false, "font_size": 17, "lines_coords": [[[337.0, 612.0], [518.0, 6