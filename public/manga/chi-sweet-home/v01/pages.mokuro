{"version": "0.2.4", "title": "v01", "title_uuid": "87d543f3-cb1b-43a6-92a1-da5ffa26a036", "volume": "pages", "volume_uuid": "0211c14a-ff28-4ab2-aaba-57ed13369725", "pages": [{"version": "0.2.4", "img_width": 1500, "img_height": 556, "blocks": [{"box": [357, 16, 443, 51], "vertical": false, "font_size": 38, "lines_coords": [[[357.0, 13.0], [443.0, 13.0], [443.0, 54.0], [357.0, 54.0]]], "lines": ["２０１６年１月３０日土曜日のホームページで"]}, {"box": [362, 41, 714, 153], "vertical": false, "font_size": 44, "lines_coords": [[[372.0, 95.0], [691.0, 99.0], [691.0, 147.0], [372.0, 143.0]]], "lines": ["スイートホーム"]}, {"box": [31, 226, 215, 305], "vertical": false, "font_size": 13, "lines_coords": [[[38.0, 227.0], [209.0, 227.0], [209.0, 241.0], [38.0, 241.0]], [[38.0, 242.0], [209.0, 242.0], [209.0, 256.0], [38.0, 256.0]], [[36.0, 256.0], [208.0, 256.0], [208.0, 271.0], [36.0, 271.0]], [[35.0, 270.0], [208.0, 270.0], [208.0, 288.0], [35.0, 288.0]], [[38.0, 287.0], [121.0, 287.0], [121.0, 301.0], [38.0, 301.0]]], "lines": ["うちには洋服を利用ハーブの女のつがい", "ます。猫は男性物が使いだと思っていた", "あのに、彼女は思われるのが大好き。はりの", "あっ、あぁぁぁ．．．。付いたノズルでフラッシングしてあげると", "うっとりしています。"]}, {"box": [501, 215, 570, 236], "vertical": false, "font_size": 18, "lines_coords": [[[505.0, 217.0], [566.0, 217.0], [566.0, 237.0], [505.0, 237.0]]], "lines": ["ｖｏｌｄｍｅ"]}, {"box": [161, 304, 209, 314], "vertical": false, "font_size": 10, "lines_coords": [[[161.0, 304.0], [209.0, 304.0], [209.0, 314.0], [161.0, 314.0]]], "lines": ["．．．なみかなた"]}, {"box": [360, 427, 708, 512], "vertical": false, "font_size": 85, "lines_coords": [[[360.0, 427.0], [708.0, 427.0], [708.0, 512.0], [360.0, 512.0]]], "lines": ["この子猫、拾ってください。モンクはいいのはまだナールカラーですが、"]}, {"box": [359, 426, 711, 512], "vertical": false, "font_size": 29, "lines_coords": [[[361.0, 425.0], [703.0, 425.0], [703.0, 464.0], [361.0, 464.0]], [[380.0, 461.0], [704.0, 461.0], [704.0, 484.0], [380.0, 484.0]]], "lines": ["この子猫、拾ってください。", "ニュングや大人気の経済面、完全オープン一ルカラーで単行本化！"]}, {"box": [739, 403, 758, 550], "vertical": true, "font_size": 19, "lines_coords": [[[739.0, 403.0], [758.0, 403.0], [758.0, 550.0], [739.0, 550.0]]], "lines": ["こちらがたた"]}, {"box": [877, 67, 895, 77], "vertical": false, "font_size": 10, "lines_coords": [[[877.0, 67.0], [895.0, 67.0], [895.0, 77.0], [877.0, 77.0]]], "lines": ["４３６"]}, {"box": [928, 29, 1086, 137], "vertical": false, "font_size": 14, "lines_coords": [[[936.0, 29.0], [1025.0, 29.0], [1025.0, 43.0], [936.0, 43.0]], [[934.0, 54.0], [1062.0, 54.0], [1062.0, 68.0], [934.0, 68.0]], [[936.0, 81.0], [1042.0, 81.0], [1042.0, 92.0], [936.0, 92.0]], [[933.0, 95.0], [1078.0, 95.0], [1078.0, 109.0], [933.0, 109.0]], [[933.0, 119.0], [1064.0, 119.0], [1064.0, 134.0], [933.0, 134.0]]], "lines": ["雑誌「４６２９３－４３", "ＩＳＢＭ４－Ｏ６－３３４９４３－８", "９９７９¥８４８Ｅ．（０", "講談社でーニングＫＣＯＸ", "定価・本体８４８円（税別"]}, {"box": [840, 134, 893, 144], "vertical": false, "font_size": 10, "lines_coords": [[[840.0, 134.0], [893.0, 134.0], [893.0, 144.0], [840.0, 144.0]]], "lines": ["＞７９００８４８２"]}, {"box": [1413, 172, 1443, 413], "vertical": true, "font_size": 25, "lines_coords": [[[1416.0, 172.0], [1441.0, 172.0], [1438.0, 411.0], [1413.0, 411.0]]], "lines": ["チーズスイートホーム："]}, {"box": [798, 433, 1109, 545], "vertical": false, "font_size": 11, "lines_coords": [[[848.0, 431.0], [896.0, 431.0], [896.0, 440.0], [848.0, 440.0]], [[830.0, 442.0], [919.0, 442.0], [919.0, 457.0], [830.0, 457.0]], [[805.0, 457.0], [915.0, 457.0], [915.0, 471.0], [805.0, 471.0]], [[804.0, 472.0], [873.0, 472.0], [873.0, 486.0], [804.0, 486.0]]], "lines": ["．．．", "．．．いたずるんだ？", "無料料金・銀・インク・お", "．．．"]}], "img_path": "0001.jpg"}, {"version": "0.2.4", "img_width": 1500, "img_height": 556, "blocks": [{"box": [357, 16, 443, 51], "vertical": false, "font_size": 38, "lines_coords": [[[357.0, 13.0], [443.0, 13.0], [443.0, 54.0], [357.0, 54.0]]], "lines": ["２０１６年１月３０日土曜日のホームページで"]}, {"box": [362, 41, 714, 153], "vertical": false, "font_size": 42, "lines_coords": [[[373.0, 99.0], [692.0, 99.0], [692.0, 144.0], [373.0, 144.0]]], "lines": ["スイートホーム"]}, 