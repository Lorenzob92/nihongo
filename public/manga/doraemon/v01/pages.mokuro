0, 1021.0], [427.0, 1095.0], [271.0, 1095.0]]], "lines": ["・Ｆ・不二雄", "藤子・Ｆ"]}], "img_path": "0003.jpg"}, {"version": "0.2.4", "img_width": 764, "img_height": 1200, "blocks": [{"box": [217, 150, 373, 173], "vertical": false, "font_size": 23, "lines_coords": [[[217.0, 150.0], [373.0, 150.0], [373.0, 173.0], [217.0, 173.0]]], "lines": ["ドラえもん□"]}, {"box": [217, 222, 312, 237], "vertical": false, "font_size": 15, "lines_coords": [[[217.0, 222.0], [312.0, 222.0], [312.0, 237.0], [217.0, 237.0]]], "lines": ["みらいくに"]}, {"box": [217, 189, 372, 205], "vertical": false, "font_size": 16, "lines_coords": [[[217.0, 189.0], [372.0, 189.0], [372.0, 205.0], [217.0, 205.0]]], "lines": ["そういえばそうですね。それでも、"]}, {"box": [214, 241, 604, 261], "vertical": false, "font_size": 20, "lines_coords": [[[214.0, 241.0], [604.0, 241.0], [604.0, 261.0], [214.0, 261.0]]], "lines": ["未来の国からはるばると．．．．．．．．"]}, {"box": [543, 151, 616, 176], "vertical": false, "font_size": 25, "lines_coords": [[[543.0, 151.0], [616.0, 151.0], [616.0, 176.0], [543.0, 176.0]]], "lines": ["もくじ"]}, {"box": [529, 187, 596, 203], "vertical": false, "font_size": 16, "lines_coords": [[[529.0, 187.0], [596.0, 187.0], [596.0, 203.0], [529.0, 203.0]]], "lines": ["Ｗｉｎｄｏｗｓｗｉｌｌ"]}, {"box": [201, 266, 515, 405], "vertical": false, "font_size": 29.2, "lines_coords": [[[363.0, 266.0], [440.0, 266.0], [440.0, 285.0], [363.0, 285.0]], [[216.0, 283.0], [515.0, 283.0], [515.0, 307.0], [216.0, 307.0]], [[212.0, 310.0], [260.0, 308.0], [261.0, 325.0], [213.0, 328.0]], [[212.0, 328.0], [445.0, 326.0], [445.0, 350.0], [212.0, 351.0]], [[201.0, 344.0], [494.0, 344.0], [494.0, 405.0], [201.0, 405.0]]], "lines": ["だかよげんだいよ", "ドラえもんの大予言．．．", "へんしん", "変身ビスケット．．．！！", "変身ヒスケット．．．！！感スバイ大作戦．．"]}, {"box": [214, 419, 340, 459], "vertical": false, "font_size": 14.5, "lines_coords": [[[215.0, 419.0], [340.0, 419.0], [340.0, 435.0], [215.0, 435.0]], [[214.0, 446.0], [283.0, 446.0], [283.0, 459.0], [214.0, 459.0]]], "lines": ["コベアベ．．．", "ふるどうぐ"]}, {"box": [312, 353, 389, 373], "vertical": false, "font_size": 20, "lines_coords": [[[312.0, 353.0], [389.0, 353.0], [389.0, 373.0], [312.0, 373.0]]], "lines": ["だいさくせん"]}, {"box": [214, 446, 469, 485], "vertical": false, "font_size": 19.0, "lines_coords": [[[367.0, 446.0], [386.0, 446.0], [386.0, 460.0], [367.0, 460.0]], [[214.0, 461.0], [469.0, 459.0], [469.0, 482.0], [214.0, 485.0]]], "lines": ["そう", "古道具きょう争．．．．．．"]}, {"box": [212, 499, 467, 532], "vertical": false, "font_size": 28, "lines_coords": [[[212.0, 503.0], [467.0, 499.0], [467.0, 527.0], [212.0, 532.0]]], "lines": ["ペコペコバッタ．．．！！"]}, {"box": [235, 655, 261, 686], "vertical": false, "font_size": 26, "lines_coords": [[[235.0, 660.0], [254.0, 655.0], [261.0, 680.0], [242.0, 686.0]]], "lines": ["こうしよう"]}, {"box": [289, 622, 311, 636], "vertical": false, "font_size": 14, "lines_coords": [[[289.0, 622.0], [311.0, 622.0], [311.0, 636.0], [289.0, 636.0]]], "lines": ["くち"]}, {"box": [174, 530, 544, 785], "vertical": false, "font_size": 42.666666666666664, "lines_coords": [[[239.0, 533.0], [278.0, 533.0], [278.0, 549.0], [239.0, 549.0]], [[206.0, 543.0], [543.0, 530.0], [544.0, 575.0], [207.0, 588.0]], [[212.0, 594.0], [427.0, 590.0], [427.0, 614.0], [212.0, 617.0]], [[210.0, 631.0], [486.0, 631.0], [486.0, 663.0], [210.0, 663.0]], [[190.0, 616.0], [543.0, 663.0], [527.0, 785.0], [174.0, 738.0]], [[291.0, 664.0], [346.0, 664.0], [346.0, 680.0], [291.0, 680.0]]], "lines": ["そんせんせー", "ご先祖さまがんばれ．．．", "かげがり．．．．．．．．", "おせし口べに．．．", "おそらくにおきに一度は百点をつけて、一生に二度は直点をしています。プロポーズ作戦というのは、", "いちど"]}, {"box": [360, 665, 412, 682], "vertical": false, "font_size": 17, "lines_coords": [[[360.0, 665.0], [412.0, 665.0], [412.0, 682.0], [360.0, 682.0]]], "lines": ["ひゃくてん"]}, {"box": [235, 771, 519, 794], "vertical": false, "font_size": 23, "lines_coords": [[[235.0, 771.0], [519.0, 771.0], [519.0, 794.0], [235.0, 794.0]]], "lines": ["○○がメメと△△する．．．"]}, {"box": [179, 711, 650, 926], "vertical": false, "font_size": 43.333333333333336, "lines_coords": [[[342.0, 711.0], [387.0, 711.0], [387.0, 727.0], [342.0, 727.0]], [[214.0, 724.0], [581.0, 727.0], [581.0, 751.0], [214.0, 747.0]], [[179.0, 732.0], [650.0, 732.0], [650.0, 877.0], [179.0, 877.0]], [[209.0, 855.0], [618.0, 850.0], [618.0, 887.0], [209.0, 891.0]], [[213.0, 888.0], [233.0, 888.0], [233.0, 904.0], [213.0, 904.0]], [[212.0, 902.0], [446.0, 903.0], [446.0, 926.0], [212.0, 925.0]]], "lines": ["さくせんさんだぜ", "プロポーズ作戦．．．", "プロポーズ体験については、１０００人が多くと公立するというのは雪でアッチッチしていたのです。", "ランプのけむりオバケ．．．！！？", "はし", "走れ！ウマタケ．．．！！"]}, {"box": [392, 945, 610, 970], "vertical": false, "font_size": 24, "lines_coords": [[[392.0, 946.0], [610.0, 945.0], [610.0, 969.0], [392.0, 970.0]]], "lines": ["麗藤子・Ｆ・不二雄の"]}, {"box": [498, 901, 619, 933], "vertical": false, "font_size": 25, "lines_coords": [[[498.0, 908.0], [618.0, 901.0], [619.0, 926.0], [499.0, 933.0]]], "lines": ["．．．．．．．．"]}], "img_path": "0004.jpg"}, {"version": "0.2.4", "img_width": 764, "img_height": 1200, "blocks": [{"box": [83, 67, 285, 103], "vertical": false, "font_size": 33, "lines_coords": [[[83.0, 67.0], [285.0, 70.0], [285.0, 103.0], [83.0, 100.0]]], "lines": ["ドラえもん口"]}, {"box": [77, 128, 287, 154], "vertical": false, "font_size": 24, "lines_coords": [[[77.0, 128.0], [287.0, 131.0], [287.0, 154.0], [77.0, 152.0]]], "lines": ["てんとう虫コミックス"]}, {"box": [153, 574, 298, 590], "vertical": false, "font_size": 16, "lines_coords": [[[153.0, 574.0], [298.0, 574.0], [298.0, 590.0], [153.0, 590.0]]], "lines": ["２０１４年１１月２０日"]}, {"box": [302, 208, 684, 429], "vertical": false, "font_size": 19, "lines_coords": [[[302.0, 210.0], [478.0, 208.0], [478.0, 232.0], [302.0, 234.0]], [[302.0, 239.0], [674.0, 239.0], [674.0, 258.0], [302.0, 258.0]], [[303.0, 263.0], [408.0, 263.0], [408.0, 283.0], [303.0, 283.0]], [[305.0, 288.0], [677.0, 288.0], [677.0, 304.0], [305.0, 304.0]], [[303.0, 310.0], [677.0, 310.0], [677.0, 330.0], [303.0, 330.0]], [[302.0, 333.0], [679.0, 333.0], [679.0, 353.0], [302.0, 353.0]], [[303.0, 358.0], [669.0, 359.0], [669.0, 377.0], [303.0, 376.0]], [[302.0, 382.0], [667.0, 383.0], [667.0, 399.0], [302.0, 398.0]], [[304.0, 407.0], [506.0, 407.0], [506.0, 424.0], [304.0, 424.0]]], "lines": ["藤子・Ｆ・不二雄", "本名、藤本弘。１９３３（昭和８）年１２月１日、蒼山県", "高岡市生まれ。", "１９５１（昭和２６）年、「天使の玉ちゃん」でデビュー", "安孫子素雄氏とふたりで〝藤子不二雄、名義作品", "を発表。児童まんがの期時代を築き、第一人者に", "代表作「ドラえもん」「オバケのＱ太郎〈共著〉", "「パーマン」「キテレッ大百科「エスパー魔美", "「ＳＦ異色知編集など多数"]}, {"box": [154, 544, 482, 595], "vertical": false, "font_size": 22.0, "lines_coords": [[[154.0, 547.0], [325.0, 547.0], [325.0, 563.0], [154.0, 563.0]], [[324.0, 544.0], [482.0, 544.0], [482.0, 569.0], [324.0, 569.0]], [[358.0, 570.0], [481.0, 570.0], [481.0, 595.0], [358.0, 595.0]]], "lines": ["１９７４年８月１日、お", "初版第１刷発行", "第２２８刑発行"]}, {"box": [609, 547, 679, 560], "vertical": false, "font_size": 13, "lines_coords": [[[609.0, 547.0], [679.0, 547.0], [679.0, 560.0], [609.0, 560.0]]], "lines": ["（検印廃止"]}, {"box": [148, 673, 216, 701], "vertical": false, "font_size": 27.5, "lines_coords": [[[190.0, 673.0], [216.0, 673.0], [216.0, 700.0], [190.0, 700.0]], [[148.0, 673.0], [173.0, 673.0], [173.0, 701.0], [148.0, 701.0]]], "lines": ["者", "著"]}, {"box": [139, 716, 224, 775], "vertical": false, "font_size": 51, "lines_coords": [[[144.0, 716.0], [224.0, 724.0], [220.0, 775.0], [139.0, 767.0]]], "lines": ["発行者"]}, {"box": [151, 796, 214, 820], "vertical": false, "font_size": 21, "lines_coords": [[[152.0, 796.0], [214.0, 799.0], [213.0, 820.0], [151.0, 817.0]]], "lines": ["印刷所"]}, {"box": [283, 653, 536, 825], "vertical": false, "font_size": 43, "lines_coords": [[[302.0, 673.0], [390.0, 673.0], [390.0, 703.0], [302.0, 703.0]], [[283.0, 691.0], [420.0, 653.0], [440.0, 721.0], [303.0, 759.0]], [[302.0, 714.0], [329.0, 714.0], [329.0, 761.0], [302.0, 761.0]], [[369.0, 730.0], [396.0, 730.0], [396.0, 760.0], [369.0, 760.0]], [[417.0, 692.0], [442.0, 692.0], [442.0, 721.0], [417.0, 721.0]], [[308.0, 799.0], [523.0, 799.0], [523.0, 819.0], [308.0, 819.0]], [[440.0, 670.0], [509.0, 670.0], [509.0, 706.0], [440.0, 706.0]], [[435.0, 737.0], [459.0, 737.0], [459.0, 755.0], [435.0, 755.0]], [[471.0, 664.0], [536.0, 664.0], [536.0, 768.0], [471.0, 768.0]]], "lines": ["藤子・", "．．．トッチ・アの隊操探", "塚", "原", "ロ", "羽書印刷株式会社社会社", "不二", "何", "雄７４郎二二"]}, {"box": [79, 862, 696, 932], "vertical": false, "font_size": 34.666666666666664, "lines_coords": [[[159.0, 862.0], [696.0, 869.0], [694.0, 932.0], [158.0, 925.0]], [[79.0, 889.0], [176.0, 889.0], [176.0, 914.0], [79.0, 914.0]], [[172.0, 901.0], [516.0, 902.0], [516.0, 918.0], [172.0, 917.0]]], "lines": ["新月１０００年１０月２０日以内の３００８年３月３０日（金）小学館・", "発行所", "【ＴＯＰでの「米米軍」ＴＥＬ・販売ＧＯ（５３２）！５３１）５５６毎年１２年の編集中３（３２６）１３８８"]}, {"box": [65, 943, 697, 1136], "vertical": false, "font_size": 17, "lines_coords": [[[78.0, 947.0], [687.0, 947.0], [687.0, 971.0], [78.0, 971.0]], [[85.0, 962.0], [689.0, 962.0], [689.0, 986.0], [85.0, 986.0]], [[85.0, 981.0], [420.0, 981.0], [420.0, 1001.0], [85.0, 1001.0]], [[79.0, 998.0], [687.0, 998.0], [687.0, 1018.0], [79.0, 1018.0]], [[86.0, 1016.0], [678.0, 1016.0], [678.0, 1035.0], [86.0, 1035.0]], [[77.0, 1032.0], [381.0, 1032.0], [381.0, 1052.0], [77.0, 1052.0]], [[90.0, 1051.0], [684.0, 1051.0], [684.0, 1067.0], [90.0, 1067.0]], [[90.0, 1067.0], [632.0, 1067.0], [632.0, 1087.0], [90.0, 1087.0]], [[90.0, 1086.0], [554.0, 1086.0], [554.0, 1102.0], [90.0, 1102.0]], [[77.0, 1103.0], [685.0, 1103.0], [685.0, 1118.0], [77.0, 1118.0]], [[87.0, 1117.0], [420.0, 1118.0], [420.0, 1137.0], [87.0, 1136.0]]], "lines": ["●並木には「分注意しておりますが、取り扱ういか」ます。購入された落丁・乱丁（本のベージ）製法多を開設して「銀行はこの坂は落ちや朝日の間違いの場合はお", "逆本には「２０点しくお取り替えいたします。購入につか明らぬまいね」または「おまっかく落ち着いているので、された素材名を明日して「朝作品」あて「個人的で落ちや朝の夕州遊りの場合はおにお送りください。送料小出食担", "取り行えてんじょにてお取り替えいたし大事の購入されたアイテムはしています。調作品は１１月２５日に２０１８年では", "ここでお取り合えましょう。●本書の一部あるいは全部をＷｅｂサイトではあの時は１０月２０日から３０歳前で被要素報・上演・教室等をすることがありませんでしょう。とは、法律で認められた場合を払ってみません。", "新き、著作者などが出版者の権利のためにあらかは．．．私だけどなります。あらがしかしこは、はい。他のクラスにありがとうございます。", "例え、それねよりお互く公益社団法人は大事な本製製権センター委託以設物コレートが認めています。エステレージャー", "本書を無断で複数コピーすることはとは、著作権法上の例外を除き、禁じられています。本当をコピー", "本当と無論、スタートされる場合は、事前に公益社団法１００万人これは、１０００人目本複製権センター今週末で、楽しみにしまうのですが、１００円以上の作品を受けてください。このブロックスの", "ＪＲＲＣ（ＡＴＡＲＡＣ）ＡＣＬＩＮＴＯ／／ＮＡＮＡＴＥＲＴＡＣＡＴＣＯＳＣメール：ｉＰｒｏｉｎｃ＿ｉｎｆｏ＠ｉｔｈｏｎｔ．Ｃｏｐｌｅの電話は「３０１－２８２０１２８８２", "●本書の記事．．．クセデータ化学の無術攻撃のは著作権法人での解外を除き禁じられています。代行来客等の第", "本音の電子ノークルの三者による本書の能子お魚物教授はわからない。自殺要も認められておりません。"]}, {"box": [492, 1147, 685, 1162], "vertical": false, "font_size": 15, "lines_coords": [[[492.0, 1147.0], [685.0, 1147.0], [685.0, 1162.0], [492.0, 1162.0]]], "lines": ["ＩＳＢＮ４－０９－１４０００１－９"]}], "img_path": "0005.jpg"}, {"version": "0.2.4", "img_width": 764, "img_height": 1200, "blocks": [{"box": [65, 819, 168, 928], "vertical": false, "font_size": 59.0, "lines_coords": [[[83.0, 819.0], [97.0, 819.0], [97.0, 844.0], [83.0, 844.0]], [[65.0, 835.0], [168.0, 835.0], [168.0, 928.0], [65.0, 928.0]]], "lines": ["書»", "ト蔵桜守名名行書著発"]}, {"box": [132, 813, 680, 945], "vertical": false, "font_size": 25.2, "lines_coords": [[[173.0, 815.0], [332.0, 813.0], [332.0, 837.0], [173.0, 840.0]], [[132.0, 820.0], [146.0, 820.0], [146.0, 848.0], [132.0, 848.0]], [[174.0, 849.0], [510.0, 849.0], [510.0, 877.0], [174.0, 877.0]], [[175.0, 887.0], [343.0, 887.0], [343.0, 910.0], [175.0, 910.0]], [[178.0, 922.0], [680.0, 922.0], [680.0, 945.0], [178.0, 945.0]]], "lines": ["ドラえもん．．．", "名", "藤子・Ｐ・不二雄／〇藤子プロ", "株式会社小学館", "〒１０１－８００１東京都千代田区一ツ橋２・３－１"]}, {"box": [82, 994, 530, 1018], "vertical": false, "font_size": 24, "lines_coords": [[[82.0, 994.0], [530.0, 994.0], [530.0, 1018.0], [82.0, 1018.0]]], "lines": ["電子書籍制作会社株式会社昭和ブライト"]}], "img_path": "0006.jpg"}, {"version": "0.2.4", "img_width": 764, "img_height": 1200, "blocks": [{"box": [78, 150, 686, 221], "vertical": false, "font_size": 69, "lines_coords": [[[78.0, 150.0], [686.0, 152.0], [686.0, 221.0], [78.0, 219.0]]], "lines": ["未来の国からはるばると"]}], "img_path": "0007.jpg"}, {"version": "0.2.4", "img_width": 764, "img_height": 1200, "blocks": [{"box": [619, 213, 671, 344], "vertical": true, "font_size": 22, "lines_coords": [[[646.0, 213.0], [671.0, 213.0], [671.0, 297.0], [646.0, 297.0]], [[619.0, 215.0], [639.0, 215.0], [639.0, 344.0], [619.0, 344.0]]], "lines": ["のどかな", "お正月だなあ。"]}, {"box": [456, 175, 538, 285], "vertical": true, "font_size": 22, "lines_coords": [[[506.0, 176.0], [531.0, 176.0], [531.0, 242.0], [506.0, 242.0]], [[483.0, 179.0], [503.0, 179.0], [503.0, 278.0], [483.0, 278.0]], [[456.0, 175.0], [476.0, 175.0], [479.0, 284.0], [459.0, 284.0]]], "lines": ["今年は", "いいことが", "ありそうだ。"]}, {"box": [80, 126, 180, 198], "vertical": true, "font_size": 26, "lines_coords": [[[154.0, 127.0], [180.0, 127.0], [180.0, 196.0], [154.0, 196.0]], [[130.0, 127.0], [155.0, 127.0], [155.0, 192.0], [130.0, 192.0]], [[105.0, 127.0], [131.0, 127.0], [131.0, 189.0], [105.0, 189.0]], [[80.0, 126.0], [105.0, 126.0], [105.0, 198.0], [80.0, 198.0]]], "lines": ["いやあ、", "ろくな", "ことが", "ないね。"]}, {"box": [53, 370, 180, 478], "vertical": true, "font_size": 27, "lines_coords": [[[137.0, 370.0], [180.0, 370.0], [180.0, 425.0], [137.0, 425.0]], [[113.0, 377.0], [138.0, 377.0], [138.0, 459.0], [113.0, 459.0]], [[84.0, 377.0], [105.0, 377.0], [105.0, 478.0], [84.0, 478.0]], [[53.0, 375.0], [73.0, 375.0], [76.0, 467.0], [56.0, 467.0]]], "lines": ["野比", "のび太は", "三十分後に", "首をつる。"]}, {"box": [614, 631, 700, 755], "vertical": true, "font_size": 23, "lines_coords": [[[670.0, 632.0], [693.0, 632.0], [693.0, 755.0], [670.0, 755.0]], [[640.0, 633.0], [662.0, 633.0], [662.0, 735.0], [640.0, 735.0]], [[614.0, 631.0], [639.0, 631.0], [639.0, 687.0], [614.0, 687.0]]], "lines": ["四十分後には", "火あぶりに", "なる。"]}, {"box": [359, 629, 435, 741], "vertical": true, "font_size": 23, "lines_coords": [[[403.0, 630.0], [432.0, 629.0], [435.0, 701.0], [406.0, 703.0]], [[384.0, 635.0], [405.0, 635.0], [405.0, 734.0], [384.0, 734.0]], [[359.0, 633.0], [379.0, 633.0], [379.0, 740.0], [359.0, 740.0]]], "lines": ["だれだ、", "へんなこと", "いうやつは"]}, {"box": [89, 617, 166, 720], "vertical": true, "font_size": 41, "lines_coords": [[[118.0, 617.0], [166.0, 625.0], [154.0, 692.0], [106.0, 684.0]], [[89.0, 628.0], [123.0, 6