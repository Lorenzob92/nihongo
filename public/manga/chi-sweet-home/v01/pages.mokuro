 710.0], [251.0, 726.0], [173.0, 726.0]]], "lines": ["キッチン"]}, {"box": [419, 1026, 461, 1047], "vertical": false, "font_size": 21, "lines_coords": [[[419.0, 1026.0], [461.0, 1026.0], [461.0, 1047.0], [419.0, 1047.0]]], "lines": ["お庭"]}], "img_path": "0168.jpg"}, {"version": "0.2.4", "img_width": 841, "img_height": 1200, "blocks": [{"box": [74, 68, 491, 298], "vertical": false, "font_size": 15, "lines_coords": [[[78.0, 70.0], [486.0, 70.0], [486.0, 86.0], [78.0, 86.0]], [[79.0, 91.0], [490.0, 91.0], [490.0, 110.0], [79.0, 110.0]], [[77.0, 115.0], [490.0, 115.0], [490.0, 130.0], [77.0, 130.0]], [[78.0, 136.0], [490.0, 136.0], [490.0, 152.0], [78.0, 152.0]], [[78.0, 158.0], [489.0, 158.0], [489.0, 174.0], [78.0, 174.0]], [[78.0, 178.0], [483.0, 178.0], [483.0, 197.0], [78.0, 197.0]], [[77.0, 208.0], [491.0, 208.0], [491.0, 228.0], [77.0, 228.0]], [[78.0, 232.0], [187.0, 232.0], [187.0, 248.0], [78.0, 248.0]], [[77.0, 262.0], [322.0, 261.0], [322.0, 278.0], [77.0, 279.0]], [[154.0, 283.0], [449.0, 282.0], [449.0, 299.0], [154.0, 300.0]]], "lines": ["「チーズスイートホー一ム，第１巻は、０４年のモールニング６，８，１０，１２，", "１４．１６．０．２０１８年７月２９日３３．３５．３８．４０．４２４号に掲", "載された作品を収録したものです。編集部では、この作品に対する皆", "様のご意見・ご感想をお待ちしております。なお、お送りいただいたお", "手紙・おハガキは、ご記入いただいた個人情報を含めて作者にお渡し", "することがありますので、あらかしめご了解のうえ、お送りください。", "また、今後単行本にまとめてほしい仲品がありましたら、編集部まで", "お知らせください。", "〒１１２．００１東京都文京区音羽２－１２－２１", "講談社モーニング編集部モーニングＫＣＤＸ係"]}, {"box": [76, 529, 270, 566], "vertical": false, "font_size": 15.5, "lines_coords": [[[76.0, 529.0], [270.0, 529.0], [270.0, 544.0], [76.0, 544.0]], [[76.0, 550.0], [270.0, 550.0], [270.0, 566.0], [76.0, 566.0]]], "lines": ["２００４年１１月２２日第１刷発行", "２０１５年６月１０日－第５期発行"]}, {"box": [79, 488, 388, 512], "vertical": false, "font_size": 24, "lines_coords": [[[79.0, 488.0], [388.0, 488.0], [388.0, 512.0], [79.0, 512.0]]], "lines": ["チーズスイートホームい"]}, {"box": [474, 503, 619, 515], "vertical": false, "font_size": 12, "lines_coords": [[[474.0, 503.0], [619.0, 503.0], [619.0, 515.0], [474.0, 515.0]]], "lines": ["パーに表示してあります）"]}, {"box": [77, 601, 106, 615], "vertical": false, "font_size": 14, "lines_coords": [[[77.0, 601.0], [106.0, 601.0], [106.0, 615.0], [77.0, 615.0]]], "lines": ["著者"]}, {"box": [76, 632, 122, 683], "vertical": false, "font_size": 17.5, "lines_coords": [[[76.0, 632.0], [122.0, 632.0], [122.0, 650.0], [76.0, 650.0]], [[76.0, 666.0], [122.0, 666.0], [122.0, 683.0], [76.0, 683.0]]], "lines": ["発行者", "発行所"]}, {"box": [74, 847, 124, 897], "vertical": false, "font_size": 16, "lines_coords": [[[74.0, 847.0], [124.0, 847.0], [124.0, 864.0], [74.0, 864.0]], [[74.0, 881.0], [124.0, 881.0], [124.0, 897.0], [74.0, 897.0]]], "lines": ["ＥＤ刷所", "製本所"]}, {"box": [76, 783, 309, 829], "vertical": false, "font_size": 16, "lines_coords": [[[76.0, 783.0], [105.0, 783.0], [105.0, 798.0], [76.0, 798.0]], [[76.0, 814.0], [309.0, 814.0], [309.0, 829.0], [76.0, 829.0]]], "lines": ["はい", "本文デザインシラキハラメグ"]}, {"box": [180, 782, 329, 898], "vertical": false, "font_size": 16, "lines_coords": [[[180.0, 782.0], [228.0, 782.0], [228.0, 799.0], [180.0, 799.0]], [[181.0, 848.0], [329.0, 848.0], [329.0, 864.0], [181.0, 864.0]], [[180.0, 882.0], [312.0, 882.0], [312.0, 898.0], [180.0, 898.0]]], "lines": ["葛西恵", "大日本日Ｄ刷株式会社", "株式会社国宝社"]}, {"box": [176, 600, 595, 732], "vertical": false, "font_size": 17, "lines_coords": [[[182.0, 600.0], [278.0, 600.0], [278.0, 616.0], [182.0, 616.0]], [[183.0, 635.0], [262.0, 635.0], [262.0, 648.0], [183.0, 648.0]], [[179.0, 663.0], [305.0, 663.0], [305.0, 683.0], [179.0, 683.0]], [[183.0, 691.0], [465.0, 691.0], [465.0, 707.0], [183.0, 707.0]], [[180.0, 711.0], [593.0, 708.0], [593.0, 728.0], [180.0, 731.0]]], "lines": ["こなみかなた", "カナ風隆夫", "株式会社・講談社", "〒１１２－８００１東京都文京区音羽２－１２－２１", "電話「編集部（Ｃ３）３９４５－９１５５．販売部（０３）５３９５．３６０８"]}, {"box": [71, 923, 179, 962], "vertical": false, "font_size": 39, "lines_coords": [[[71.0, 923.0], [179.0, 923.0], [179.0, 962.0], [71.0, 962.0]]], "lines": ["講｜談｜社"]}, {"box": [72, 986, 386, 1014], "vertical": false, "font_size": 11.5, "lines_coords": [[[72.0, 986.0], [215.0, 986.0], [215.0, 998.0], [72.0, 998.0]], [[72.0, 1003.0], [386.0, 1003.0], [386.0, 1014.0], [72.0, 1014.0]]], "lines": ["＠Ｋａｎａｎｉｋａｍａｔａ２００４", "「本書の無断複数（コピー１．は著作権法上での例外を除き、禁じられて"]}, {"box": [76, 1034, 463, 1046], "vertical": false, "font_size": 12, "lines_coords": [[[76.0, 1034.0], [463.0, 1034.0], [463.0, 1046.0], [76.0, 1046.0]]], "lines": ["モーニングＫＣＤＸ１９４３１５時Ｎ４－０６－３３４９４３ＭＤＣ７２８１６４Ｐ１９ｃｈ"]}, {"box": [74, 1066, 498, 1096], "vertical": false, "font_size": 13.5, "lines_coords": [[[74.0, 1066.0], [498.0, 1066.0], [498.0, 1078.0], [74.0, 1078.0]], [[74.0, 1080.0], [460.0, 1081.0], [460.0, 1096.0], [74.0, 1095.0]]], "lines": ["落丁乱丁本は調入書店名を明記のうえ、小社業務部院にお送りください。送料か社会担にて", "なお、この本についてのお問い合わせは、モーニング編集部列にお願いいたします。"]}, {"box": [587, 1068, 727, 1076], "vertical": false, "font_size": 8, "lines_coords": [[[587.0, 1068.0], [727.0, 1068.0], [727.0, 1076.0], [587.0, 1076.0]]], "lines": ["します（電話の３ち３９５．３６０３"]}], "img_path": "0169.jpg"}, {"version": "0.2.4", "img_width": 841, "img_height": 1200, "blocks": [{"box": [596, 41, 740, 72], "vertical": false, "font_size": 23, "lines_coords": [[[599.0, 43.0], [736.0, 43.0], [736.0, 66.0], [599.0, 66.0]]], "lines": ["次巻予告"]}, {"box": [618, 495, 708, 723], "vertical": true, "font_size": 63, "lines_coords": [[[646.0, 495.0], [708.0, 506.0], [680.0, 675.0], [618.0, 664.0]]], "lines": ["大変だー"]}, {"box": [428, 726, 465, 791], "vertical": true, "font_size": 37, "lines_coords": [[[428.0, 726.0], [465.0, 726.0], [465.0, 791.0], [428.0, 791.0]]], "lines": ["！"]}, {"box": [299, 713, 379, 874], "vertical": true, "font_size": 41, "lines_coords": [[[299.0, 724.0], [339.0, 713.0], [375.0, 849.0], [336.0, 860.0]]], "lines": ["おちう"]}], "img_path": "0170.jpg"}, {"version": "0.2.4", "img_width": 841, "img_height": 1200, "blocks": [{"box": [60, 80, 291, 189], "vertical": false, "font_size": 42.0, "lines_coords": [[[78.0, 112.0], [161.0, 114.0], [161.0, 135.0], [78.0, 133.0]], [[60.0, 127.0], [278.0, 80.0], [291.0, 142.0], [73.0, 189.0]]], "lines": ["空か", "突如現れ"]}, {"box": [166, 99, 518, 250], "vertical": false, "font_size": 57.333333333333336, "lines_coords": [[[166.0, 108.0], [361.0, 99.0], [365.0, 166.0], [169.0, 175.0]], [[270.0, 160.0], [518.0, 171.0], [515.0, 250.0], [267.0, 240.0]], [[412.0, 180.0], [513.0, 169.0], [515.0, 194.0], [414.0, 205.0]]], "lines": ["如現れた", "巨大猫", "猫"]}, {"box": [83, 356, 149, 455], "vertical": true, "font_size": 30, "lines_coords": [[[106.0, 360.0], [140.0, 356.0], [149.0, 431.0], [115.0, 435.0]], [[83.0, 367.0], [108.0, 363.0], [122.0, 450.0], [97.0, 454.0]]], "lines": ["なんか", "きになう"]}, {"box": [129, 414, 689, 557], "vertical": false, "font_size": 72, "lines_coords": [[[141.0, 414.0], [558.0, 408.0], [559.0, 518.0], [142.0, 523.0]], [[361.0, 477.0], [456.0, 477.0], [456.0, 538.0], [361.0, 538.0]], [[408.0, 468.0], [551.0, 473.0], [549.0, 548.0], [406.0, 543.0]], [[349.0, 497.0], [686.0, 494.0], [686.0, 560.0], [349.0, 563.0]]], "lines": ["山田家の平和など", "．．．", "．．．", "見せてるから．．．"]}, {"box": [315, 1028, 461, 1094], "vertical": false, "font_size": 38.0, "lines_coords": [[[315.0, 1048.0], [460.0, 1045.0], [461.0, 1091.0], [316.0, 1094.0]], [[318.0, 1038.0], [388.0, 1028.0], [392.0, 1058.0], [322.0, 1067.0]]], "lines": ["訪れる", "言わない"]}, {"box": [42, 1127, 739, 1178], "vertical": false, "font_size": 30, "lines_coords": [[[43.0, 1127.0], [739.0, 1148.0], [737.0, 1178.0], [42.0, 1157.0]]], "lines": ["チーズスイートホーム単行本第２巻、いいよ『発売予定！！"]}], "img_path": "0171.jpg"}, {"version": "0.2.4", "img_width": 841, "img_height": 1200, "blocks": [{"box": [86, 45, 378, 77], "vertical": false, "font_size": 26, "lines_coords": [[[86.0, 47.0], [373.0, 44.0], [373.0, 72.0], [86.0, 74.0]]], "lines": ["こなみかなたの単行本"]}, {"box": [124, 206, 711, 323], "vertical": false, "font_size": 24, "lines_coords": [[[175.0, 211.0], [678.0, 204.0], [678.0, 228.0], [175.0, 235.0]], [[223.0, 238.0], [625.0, 232.0], [625.0, 259.0], [223.0, 265.0]], [[141.0, 267.0], [707.0, 260.0], [707.0, 287.0], [141.0, 294.0]], [[221.0, 298.0], [636.0, 292.0], [636.0, 317.0], [221.0, 323.0]]], "lines": ["よろす屋「まるふく」在住のふくふくは、目つきが悪くて、", "ちょっぴりおデラぶってぶてしいのに小心者。", "今日もふにゃ〜んと甘えておはあちゃんにごはんをおねだり。", "そんなふくふくのはのほのあったか猫日記！！"]}, {"box": [101, 803, 137, 816], "vertical": false, "font_size": 13, "lines_coords": [[[101.0, 803.0], [137.0, 803.0], [137.0, 816.0], [101.0, 816.0]]], "lines": ["．．．"]}, {"box": [429, 774, 803, 976], "vertical": false, "font_size": 46, "lines_coords": [[[651.0, 774.0], [803.0, 806.0], [788.0, 878.0], [636.0, 847.0]], [[660.0, 842.0], [737.0, 842.0], [737.0, 862.0], [660.0, 862.0]], [[524.0, 948.0], [789.0, 941.0], [789.0, 969.0], [524.0, 976.0]], [[429.0, 861.0], [791.0, 842.0], [795.0, 911.0], [433.0, 930.0]], [[439.0, 904.0], [783.0, 892.0], [784.0, 933.0], [440.0, 945.0]]], "lines": ["漫画文庫漫画・", "．．．", "こちらも好評発売中！", "冬セレクト「こたつの巻」でもらえましたが、", "食セレクトほごはんの巻"]}, {"box": [99, 826, 415, 1014], "vertical": false, "font_size": 36.25, "lines_coords": [[[99.0, 828.0], [250.0, 826.0], [250.0, 862.0], [99.0, 864.0]], [[101.0, 885.0], [316.0, 885.0], [316.0, 922.0], [101.0, 922.0]], [[104.0, 931.0], [320.0, 928.0], [320.0, 967.0], [104.0, 971.0]], [[101.0, 983.0], [415.0, 978.0], [415.0, 1010.0], [101.0, 1014.0]]], "lines": ["コミックス", "いろいはには", "へと、ちりゅ", "る「を〟の巻大人気発売中"]}, {"box": [105, 1058, 309, 1101], "vertical": false, "font_size": 40, "lines_coords": [[[105.0, 1061.0], [309.0, 1058.0], [309.0, 1098.0], [105.0, 1101.0]]], "lines": ["おとぼけ猫．．"]}, {"box": [447, 1051, 602, 1091], "vertical": false, "font_size": 37, "lines_coords": [[[447.0, 1054.0], [600.0, 1051.0], [602.0, 1087.0], [448.0, 1091.0]]], "lines": ["くと暮らす。"]}], "img_path": "0172.jpg"}]}